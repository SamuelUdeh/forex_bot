# ===========================================
# FOREX SIGNAL BOT - ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# OANDA API (Forex & Metals)
# Get your API key from: https://www.oanda.com/account/tpa/personal_token
OANDA_API_KEY=your_oanda_api_key_here
OANDA_ACCOUNT_ID=your_oanda_account_id_here
OANDA_ENVIRONMENT=practice  # 'practice' or 'live'

# DERIV API (Synthetics)
# Get your API token from: https://app.deriv.com/account/api-token
DERIV_API_TOKEN=your_deriv_api_token_here
DERIV_APP_ID=1089  # Default app ID, or create your own at https://api.deriv.com/

# TELEGRAM BOT
# Create a bot via @BotFather on Telegram
# Get chat ID by messaging @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# BOT SETTINGS
DRY_RUN=true  # Set to 'false' to send real Telegram alerts
